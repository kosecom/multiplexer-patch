+        if profile and getattr(self.config, "multiplex_profiles", False):
+            plat_map = self._profile_adapters.get(profile, {})
+            adapter = plat_map.get(platform)
+            if adapter is not None:
+                return adapter
+        return self.adapters.get(platform)

